# Server port (Render/Railway set PORT automatically)
PORT=5000

# MongoDB — optional; without it, portfolio uses local JSON fallback
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/portfolio

# Admin dashboard password
ADMIN_PASSWORD=your-secure-password-here

# Frontend URL for CORS (your Vercel deployment)
FRONTEND_URL=https://portfolio-flax-theta-92.vercel.app

# Production
NODE_ENV=production
